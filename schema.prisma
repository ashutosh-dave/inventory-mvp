datasource db{
  provider = "postgresql"
  url = env("DATABASE_URL")
}

model User{
  id String @id @default(cuid())
  email String @unique
  password String
  name String
  role Role @default(WAREHOUSE_USER)
  movements StockMovement[]
  auditLogs AuditLog[]
  createdAt DateTime @default(now())
}

enum Role {
  ADMIN
  WAREHOUSE_USER
}

model Product {
  id String @id @default(cuid())
  sku String @unique
  name String
  category String
  baseUnit String
  reorderPoint Int @default(0)
  costPrice Decimal
  deletedAt DateTime?
  batches Batch[]
  createdAt DateTime @default(now())
}

model Batch {
  id String @id @default(cuid())
  batchNumber String
  productId String
  expiryDate DateTime?
  product Product @relation(fields: [productId], references: [id])
  movements StockMovement[]
  createdAt DateTime @default(now())

  @@unique([productId, batchNumber])
}

model Warehouse {
  id String @id @default(cuid())
  name String
  type WarehouseType @default(MAIN)
  movements StockMovement[]
}

enum WarehouseType {
  MAIN
  DAMAGED
  TRANSIT
}

model StockMovement {
  id String @id @default(cuid())
  batchId String
  warehouseId String
  type MovemementType
  quantity Int
  reason String?
  idempotencyKey String? @unique
  performedById String
  batch Batch @relation(fields:[batchId], references:[id])
  warehouse Warehouse @relation(fields:[warehouseId], references:[id])
  performedBy User @relation(fields:[performedById], references:[id])
  createdAt DateTime @default(now())

  @@index([batchId, warehouseId])
  @@index([createdAt])
}

enum MovementType{
  STOCK_IN
  STOCK_OUT
  ADJUSTMENT
  TRANSFER
}

model AuditLog {
  id String @id @default(cuid())
  entityType String
  entityId String
  action String
  oldValue Json?
  newValue Json?
  performedById String
  performedBy User @relation(fields:[performedById], references:[id])
  createdAt DateTime @default(now())
}
